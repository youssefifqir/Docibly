# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_db_password

# ── Application Admin ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@docibly.com
ADMIN_PASSWORD=Admin@12345!

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
GRAFANA_ROOT_URL=http://localhost:3000


# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
# Sign up at https://brevo.com — free tier: 300 emails/day, forever, no card.
# Not Resend: Resend only sends to your own account address until a domain is
# DNS-verified. Brevo only needs a single verified sender *address* (your own
# email, no domain) and can then send to any recipient — practical for a demo
# where strangers register. SMTP_USER = your Brevo login email. SMTP_PASS = an
# SMTP key generated under Transactional > Settings > SMTP relay (not your
# account password). EMAIL_FROM_ADDRESS must be the address you verified.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM_ADDRESS=your-verified-sender@example.com
EMAIL_FROM_NAME=Docibly

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ENABLED=true
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=changeme_minio_access_key
MINIO_SECRET_KEY=changeme_minio_secret_key
MINIO_BUCKET=docibly
